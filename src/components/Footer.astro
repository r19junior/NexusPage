---
import Logo from './Logo.astro';
---
<footer id="contacto" class="bg-brand-navy border-t border-brand-teal/20 text-white pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div class="col-span-1 lg:col-span-2 space-y-6 flex flex-col items-start">
        <div class="brightness-0 invert opacity-90">
          <Logo />
        </div>
        <p class="text-white/60 max-w-sm mt-6 font-medium">
          La escuela de oratoria para líderes que buscan estructurar su pensamiento y dominar la comunicación estratégica.
        </p>
      </div>
      
      <div>
        <h4 class="font-bold text-white mb-6 uppercase tracking-wider text-sm">Navegación</h4>
        <ul class="space-y-4 text-white/60">
          <li><a href="/" class="hover:text-brand-turquoise transition-colors">Inicio y Método</a></li>
          <li><a href="/programas" class="hover:text-brand-turquoise transition-colors">Programas Avanzados</a></li>
          <li><a href="/filosofia" class="hover:text-brand-turquoise transition-colors">Filosofía y Recursos</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="font-bold text-white mb-6 uppercase tracking-wider text-sm">Contacto</h4>
        <ul class="space-y-4 text-white/60">
          <li>
            <a href="https://maps.google.com/?q=Carlos+bacaflor+134,+Arequipa,+Peru" target="_blank" rel="noopener noreferrer" class="hover:text-brand-turquoise transition-colors">
              Carlos Bacaflor 134, Arequipa, Perú
            </a>
          </li>
          <li>
            <a href="tel:+51953013363" class="hover:text-brand-turquoise transition-colors">
              +51 953 013 363
            </a>
          </li>
          <li>
            <a href="mailto:grupo.nexus.aqp@gmail.com" class="hover:text-brand-turquoise transition-colors">
              grupo.nexus.aqp@gmail.com
            </a>
          </li>
          <li class="pt-4">
            <a href="https://wa.me/51953013363?text=Hola,%20quisiera%20reservar%20mi%20evaluación" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-brand-turquoise font-medium hover:text-white transition-colors">
              Reserva tu evaluación
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-white/40 text-sm">
      <p>&copy; {new Date().getFullYear()} NEXUS Escuela de Oratoria. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-brand-turquoise transition-colors">Privacidad</a>
        <a href="#" class="hover:text-brand-turquoise transition-colors">Términos legales</a>
      </div>
    </div>
  </div>
</footer>
