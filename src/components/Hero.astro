---

---

<section
  class="relative min-h-[90vh] flex items-center pt-24 pb-12 overflow-hidden"
>
  <!-- Interactive-like background nodes -->
  <div
    class="absolute inset-0 z-0 opacity-20 pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-brand-turquoise blur-3xl mix-blend-multiply"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-brand-teal blur-3xl mix-blend-multiply"
    >
    </div>
    <!-- Grid pattern -->
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 1px 1px, #0D9488 1px, transparent 0); background-size: 40px 40px; opacity: 0.15;"
    >
    </div>
  </div>

  <div
    class="max-w-7xl mx-auto px-6 relative z-10 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
  >
    <div class="space-y-8">
      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-bold font-display leading-[1.1] tracking-tight text-brand-navy"
      >
        Estructura tu <br />
        <span class="text-gradient">Mensaje</span> con <br />
        Precisión.
      </h1>

      <p
        class="text-lg md:text-xl text-brand-navy/80 max-w-lg leading-relaxed font-medium"
      >
        Domina el arte de la oratoria a través de una metodología innovadora y
        analítica. Conecta, persuade y lidera con seguridad.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <a
          href="#metodo"
          class="bg-brand-navy text-white px-8 py-4 rounded-full font-semibold hover:bg-brand-teal transition-colors text-center hover-lift flex items-center justify-center gap-2"
        >
          Descubre el Método
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
          >
        </a>
        <a
          href="/programas"
          class="glass-panel text-brand-navy px-8 py-4 rounded-full font-semibold hover:bg-white/90 transition-all text-center flex items-center justify-center"
        >
          Ver Programas
        </a>
      </div>
    </div>

    <div class="relative hidden lg:block">
      <!-- Abstract representation of the Nexus structure -->
      <div class="relative w-full aspect-square max-w-lg mx-auto">
        <div
          class="absolute inset-0 rounded-2xl border border-brand-teal/20 bg-white/40 backdrop-blur-3xl shadow-2xl overflow-hidden flex items-center justify-center"
        >
          <!-- decorative lines -->
          <svg
            class="w-full h-full opacity-80"
            viewBox="0 0 400 400"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#0D9488;stop-opacity:1"
                ></stop>
                <stop offset="100%" style="stop-color:#5EEAD4;stop-opacity:1"
                ></stop>
              </linearGradient>
            </defs>
            <!-- Intersection lines mimicking the logo's X -->
            <line
              x1="100"
              y1="100"
              x2="300"
              y2="300"
              stroke="url(#grad1)"
              stroke-width="2"
              stroke-dasharray="8 4"></line>
            <line
              x1="300"
              y1="100"
              x2="100"
              y2="300"
              stroke="url(#grad1)"
              stroke-width="2"
              stroke-dasharray="8 4"></line>
            <line
              x1="50"
              y1="200"
              x2="350"
              y2="200"
              stroke="#0F172A"
              stroke-width="1"
              stroke-opacity="0.2"></line>
            <line
              x1="200"
              y1="50"
              x2="200"
              y2="350"
              stroke="#0F172A"
              stroke-width="1"
              stroke-opacity="0.2"></line>

            <!-- Circular Nodes -->
            <circle cx="200" cy="200" r="8" fill="#5EEAD4"></circle>
            <circle cx="100" cy="100" r="4" fill="#0D9488"></circle>
            <circle cx="300" cy="300" r="4" fill="#0D9488"></circle>
            <circle cx="300" cy="100" r="4" fill="#0D9488"></circle>
            <circle cx="100" cy="300" r="4" fill="#0D9488"></circle>
            <circle cx="200" cy="50" r="3" fill="#0F172A" fill-opacity="0.5"
            ></circle>
            <circle cx="200" cy="350" r="3" fill="#0F172A" fill-opacity="0.5"
            ></circle>
            <circle cx="50" cy="200" r="3" fill="#0F172A" fill-opacity="0.5"
            ></circle>
            <circle cx="350" cy="200" r="3" fill="#0F172A" fill-opacity="0.5"
            ></circle>

            <!-- Abstract connecting paths -->
            <path
              d="M 100 100 Q 200 50 300 100"
              fill="none"
              class="stroke-brand-teal"
              stroke-opacity="0.4"
              stroke-width="1.5"></path>
            <path
              d="M 100 300 Q 200 350 300 300"
              fill="none"
              class="stroke-brand-teal"
              stroke-opacity="0.4"
              stroke-width="1.5"></path>
          </svg>
        </div>

        <!-- Floating cards -->
        <div
          class="absolute -right-8 top-1/4 glass-panel p-4 rounded-xl flex items-center gap-4 hover-lift"
        >
          <div
            class="w-10 h-10 rounded-full bg-brand-navy flex items-center justify-center text-white"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-sm font-bold text-brand-navy">Voz e Impacto</p>
            <p class="text-xs text-brand-navy/60">Dominio escénico</p>
          </div>
        </div>

        <div
          class="absolute -left-8 bottom-1/4 glass-panel p-4 rounded-xl flex items-center gap-4 hover-lift"
        >
          <div
            class="w-10 h-10 rounded-full bg-brand-teal flex items-center justify-center text-white"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
            >
          </div>
          <div>
            <p class="text-sm font-bold text-brand-navy">Innovación</p>
            <p class="text-xs text-brand-navy/60">Técnicas modernas</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
