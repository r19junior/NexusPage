---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="NEXUS | Escuela de Oratoria">
  <Header />
  
  <main>
    <Hero />
    <Features />
    
    <!-- Programas Section (Inline for simplicity) -->
    <section id="programas" class="py-24 bg-brand-bg relative overflow-hidden">
      <!-- Decorative background -->
      <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-teal/5 -skew-x-12 transform origin-top blur-2xl pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-20">
          <h2 class="text-brand-teal font-medium tracking-widest text-sm uppercase mb-4">Programas de Formación</h2>
          <h3 class="text-4xl md:text-5xl font-display font-semibold text-brand-navy mb-6">Elige tu nivel de impacto</h3>
          <p class="text-lg text-brand-navy/70">Diseñados para adaptarse a tus objetivos profesionales, desde la comunicación ejecutiva hasta el dominio total del escenario.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          <!-- Card 1 -->
          <div class="glass-panel p-10 group hover:border-brand-teal/50 transition-colors">
            <h4 class="text-2xl font-bold font-display text-brand-navy mb-2">Comunicación Ejecutiva</h4>
            <div class="text-brand-teal font-medium mb-6">Modalidad Online / 8 Semanas</div>
            <p class="text-brand-navy/70 mb-8 leading-relaxed">
              Ideal para directivos y líderes que necesitan persuadir en reuniones de alto nivel, mejorar su asertividad y estructurar sus ideas bajo presión.
            </p>
            <ul class="space-y-3 mb-10 text-brand-navy/80">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Estructuración de argumentos</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Tono y manejo de voz</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Storytelling corporativo</li>
            </ul>
            <a href="#" class="block text-center bg-brand-navy text-white py-3 rounded-full font-medium hover:bg-brand-teal transition-colors">
              Ver detalles
            </a>
          </div>
          
          <!-- Card 2 -->
          <div class="glass-panel p-10 bg-brand-navy text-white relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-brand-teal/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="absolute top-0 right-0 w-32 h-32 bg-brand-turquoise blur-3xl rounded-full opacity-20 transform translate-x-10 -translate-y-10"></div>
            
            <h4 class="text-2xl font-bold font-display text-white mb-2 relative z-10">Dominio Escénico Total</h4>
            <div class="text-brand-turquoise font-medium mb-6 relative z-10">Modalidad Presencial / 12 Semanas</div>
            <p class="text-white/80 mb-8 leading-relaxed relative z-10">
              El programa insignia de Nexus. Prepárate para conferencias masivas, TED Talks y presentaciones de alto impacto frente a multitudes.
            </p>
            <ul class="space-y-3 mb-10 text-white/90 relative z-10">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Posicionamiento espacial avanzado</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Gesticulación y anclaje</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Manejo de audiencias difíciles</li>
            </ul>
            <a href="#" class="block text-center bg-brand-turquoise text-brand-navy py-3 rounded-full font-bold hover:bg-white transition-colors relative z-10">
              Aplicar al programa
            </a>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Call to action -->
    <section class="py-24 border-t border-brand-teal/10 relative overflow-hidden">
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-turquoise/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
        <h2 class="text-4xl md:text-5xl font-display font-bold text-brand-navy mb-8">Comienza a estructurar tu éxito comunicativo</h2>
        <p class="text-xl text-brand-navy/70 mb-10 max-w-2xl mx-auto">
          La oratoria no es un don innato, es una técnica que se perfecciona con el método adecuado y el compromiso de liderar.
        </p>
        <a href="#contacto" class="inline-flex items-center gap-3 bg-brand-teal text-white px-10 py-5 rounded-full text-lg font-semibold hover:bg-brand-navy transition-all hover-lift shadow-xl shadow-brand-teal/20">
          Solicitar Evaluación Inicial
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
